{
    "name": "promptphp/intercept-support",
    "description": "Shared support utilities and configuration for Intercept middleware packages.",
    "keywords": ["laravel", "ai", "middleware", "prompt", "prompt-injection", "security"],
    "homepage": "https://intercept.promptphp.com",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Victor Ukam",
            "email": "victorjohnukam@gmail.com",
            "homepage": "https://github.com/veeqtoh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "PromptPHP\\Intercept\\Support\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PromptPHP\\Intercept\\Support\\InterceptServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}